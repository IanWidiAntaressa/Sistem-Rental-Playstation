<!DOCTYPE html>
<html lang="id">
<head>
    <title>Login - Rental PS</title>

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600&family=Inter:wght@400;600&display=swap" rel="stylesheet">

    <!-- Bootstrap & Icon -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at top, #0f2027, #0a0f1c, #000000);
            min-height: 100vh;
            color: #e0e0e0;
        }

        .cyber-card {
            background: rgba(10, 15, 28, 0.85);
            border: 1px solid rgba(0, 255, 255, 0.2);
            border-radius: 15px;
            backdrop-filter: blur(10px);
            box-shadow: 0 0 20px rgba(0, 255, 255, 0.1);
        }

        .cyber-title {
            font-family: 'Orbitron', sans-serif;
            letter-spacing: 2px;
            color: #00ffff;
            text-shadow: 0 0 8px #00ffff;
        }

        .form-control {
            background-color: #0a0f1c;
            border: 1px solid #00ffff44;
            color: #fff;
        }

        .form-control:focus {
            background-color: #0a0f1c;
            border-color: #00ffff;
            box-shadow: 0 0 10px #00ffff;
            color: #fff;
        }

        .btn-cyber {
            background: linear-gradient(90deg, #00ffff, #8a2be2);
            border: none;
            color: black;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn-cyber:hover {
            box-shadow: 0 0 15px #00ffff, 0 0 25px #8a2be2;
            transform: scale(1.02);
        }

        a {
            color: #00ffff;
        }

        a:hover {
            text-shadow: 0 0 5px #00ffff;
        }

        .icon-glow {
            color: #00ffff;
            text-shadow: 0 0 10px #00ffff;
        }
    </style>
</head>

<body class="d-flex align-items-center">

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-4">

            <div class="text-center mb-4">
                <i class="fa-solid fa-gamepad icon-glow" style="font-size: 2.5rem;"></i>
                <h4 class="fw-bold mt-2 mb-0 cyber-title">PS RENTAL PRO</h4>
                <p class="text-muted small">Access your system</p>
            </div>

            <div class="card cyber-card">
                <div class="card-body p-4">

                    <form action="/auth/login" method="POST">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Email / Username</label>
                            <input type="text" name="email" class="form-control" placeholder="input..." required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Password</label>
                            <input type="password" name="password" class="form-control" placeholder="••••••••" required>
                        </div>

                        <button class="btn btn-cyber w-100 py-2">LOGIN</button>
                    </form>

                    <hr style="border-color:#00ffff33;">

                    <div class="text-center">
                        <a href="/auth/register" class="text-decoration-none small">
                            Belum punya akun? <strong>Daftar</strong>
                        </a>
                    </div>

                    <div class="text-center mt-1">
                        <a href="/auth/register-admin" class="small">
                            <i class="fa-solid fa-shield-halved me-1"></i>Register Admin
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

</body>
</html>